# Pi Value World - Environment Variables
# Copy this file to .env and fill in your Supabase credentials

# Get these from your Supabase project dashboard:
# 1. Go to https://app.supabase.com
# 2. Select your project
# 3. Go to Settings → API
# 4. Copy the values below

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ⚠️ IMPORTANT: 
# - Never commit this file with real values to Git!
# - This file is in .gitignore for security
# - Only use for local testing
# - Production uses GitHub Actions secrets
